# ─────────────────────────────────────────────
# VPN Credentials (ProtonVPN WireGuard)
# ─────────────────────────────────────────────
# NEVER commit this file to git.
# Copy to .env and fill with your real values.

# ProtonVPN WireGuard private key (from ProtonVPN → Downloads → WireGuard configuration)
WIREGUARD_PRIVATE_KEY=YOUR_WIREGUARD_PRIVATE_KEY_HERE

# Server selection — use one of these options:
# Option A: by country (comma-separated, e.g. Netherlands,Switzerland)
VPN_SERVER_COUNTRIES=Netherlands

# Option B: by specific server name (e.g. NL#100)
# VPN_SERVER_NAMES=NL#100

# MTU — gluetun auto-discovers, but you can pin it (1400-1420 typical)
VPN_MTU=1420

# Secure Core — on = route through privacy-friendly countries first (higher latency)
#              off = direct connection to selected server (lower latency)
VPN_SECURE_CORE=off

# ─────────────────────────────────────────────
# Navidrome
# ─────────────────────────────────────────────
ND_MUSICFOLDER=/path/to/your/music

# ─────────────────────────────────────────────
# slskd
# ─────────────────────────────────────────────
SLSKD_SHARE_DIR=/path/to/your/music
SLSKD_DOWNLOAD_DIR=/path/to/your/downloads

# ─────────────────────────────────────────────
# PicoClaw Skills (SLSKD_API_KEY)
# ─────────────────────────────────────────────
# The Soulseek skill needs an API key for slskd's REST API.
# Store it in a file that is sourced by the skill scripts:
#   echo 'export SLSKD_API_KEY="your-slskd-api-key"' > ~/.picoclaw/workspace/skills/soulseek-music/scripts/env.sh
#   chmod 600 ~/.picoclaw/workspace/skills/soulseek-music/scripts/env.sh
# This file is gitignored (env.sh) and never committed.
SLSKD_API_KEY=your-slskd-api-key-here

# ─────────────────────────────────────────────
# Secrets NOT in this file (managed via systemd)
# ─────────────────────────────────────────────
# The following secrets are NOT loaded from .env. They are set directly
# in systemd service overrides so they never touch the repository:
#
# VENICE_API_KEY        → systemd override for venice-proxy.service
# PICOCLAW_CHANNELS_TELEGRAM_TOKEN → systemd override for picoclaw-gateway.service
#
# To set a systemd override, create a drop-in directory and file:
#   sudo systemctl edit venice-proxy.service
#   # Add:
#   # [Service]
#   # Environment="VENICE_API_KEY=sk-venice-xxxx"
#
#   sudo systemctl edit picoclaw-gateway.service
#   # Add:
#   # [Service]
#   # Environment="PICOCLAW_CHANNELS_TELEGRAM_TOKEN=your-telegram-bot-token"